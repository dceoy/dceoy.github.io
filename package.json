{
  "name": "dceoy.github.io",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "lint": "htmlhint \"**/*.html\" && stylelint \"**/*.css\" && oxlint . && biome check .",
    "lint:fix": "stylelint --fix \"**/*.css\" && oxlint --fix . && biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "htmlhint": "^1.9.1",
    "markdownlint-cli2": "^0.21.0",
    "oxlint": "^1.29.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1"
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard"
    ]
  }
}
