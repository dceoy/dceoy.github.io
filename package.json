{
  "name": "dceoy.github.io",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix",
    "lint": "htmlhint '**/*.html' && stylelint '**/*.css' && oxlint --no-error-on-unmatched-pattern . && biome check .",
    "lint:fix": "stylelint --fix '**/*.css' && oxlint --fix --no-error-on-unmatched-pattern . && biome check --write .",
    "format": "biome format --write . && prettier --write '*.md'",
    "format:check": "biome format . && prettier --check '*.md'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "htmlhint": "^1.9.2",
    "markdownlint-cli2": "^0.22.0",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.2",
    "stylelint": "^17.13.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-standard": "^40.0.0"
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard"
    ]
  }
}
